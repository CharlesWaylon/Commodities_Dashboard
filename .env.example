# Environment variables for Commodities Dashboard
# Copy this file to .env and fill in values as needed.
# Phase 1 requires NO API keys — all data is free.

# ── Phase 2 (Database) ─────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/commodities

# ── Optional: NewsAPI (free tier — 100 req/day dev) ───────────────────
# Get a key at https://newsapi.org/register
# NEWS_API_KEY=your_key_here

# ── Optional: Alpha Vantage (free tier — 25 req/day) ──────────────────
# Fallback if Yahoo Finance is throttled
# Get a key at https://www.alphavantage.co/support/#api-key
# ALPHA_VANTAGE_KEY=your_key_here
